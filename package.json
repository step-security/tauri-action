{
  "name": "tauri-action",
  "version": "1.0.0",
  "description": "Tauri GitHub Action",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist -m",
    "lint": "biome lint",
    "lint:write": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/tauri-action.git"
  },
  "keywords": [
    "actions",
    "tauri"
  ],
  "dependencies": {
    "@actions/artifact": "6.2.1",
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "axios": "^1.18.0",
    "execa": "9.6.1",
    "find-up-simple": "1.0.1",
    "globby": "16.2.0",
    "json5": "2.2.3",
    "smol-toml": "1.7.0",
    "string-argv": "0.3.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "24.13.2",
    "@vercel/ncc": "0.44.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
